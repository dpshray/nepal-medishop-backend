        "/vendor/product/{uuid}": {
            "post": {
                "tags": [
                    "Product"
                ],
                "summary": "Add stock for vendor products",
                "description": "Add stock details for product variations",
                "operationId": "AddVendorStock",
                "parameters": [
                    {
                        "name": "uuid",
                        "in": "path",
                        "description": "UUID of a product",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "54115543-b75c-4013-bf19-7aa4efd35240"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "stock": {
                                        "type": "array",
                                        "items": {
                                            "properties": {
                                                "product_variation_id": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "units_in_stock": {
                                                    "type": "integer",
                                                    "example": 50
                                                },
                                                "price": {
                                                    "type": "number",
                                                    "format": "float",
                                                    "example": 500
                                                }
                                            },
                                            "type": "object"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Stock added successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Stock added successfully."
                                        },
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        }
