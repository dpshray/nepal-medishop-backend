                                            "type": "string",
                                            "example": "Product detail fetched successfully."
                                        },
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "properties": {
                                                "name": {
                                                    "type": "string",
                                                    "example": "Incidunt ratione recusandae dolor quod."
                                                },
                                                "slug": {
                                                    "type": "string",
                                                    "example": "incidunt-ratione-recusandae-dolor-quod"
                                                },
                                                "brand": {
                                                    "type": "string",
                                                    "example": "AstraZeneca"
                                                },
                                                "description": {
                                                    "type": "string",
                                                    "example": "<p>Qui impedit consectetur necessitatibus eos iste odio...</p>"
                                                },
                                                "added_date": {
                                                    "type": "string",
                                                    "format": "date",
                                                    "example": "2025-09-24"
                                                },
                                                "categories": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "string",
                                                        "example": "Eye Care"
                                                    }
                                                },
                                                "tags": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "string",
                                                        "example": "Doxycycline"
                                                    }
                                                },
                                                "variations": {
                                                    "type": "array",
                                                    "items": {
                                                        "properties": {
                                                            "variation_id": {
                                                                "type": "integer",
                                                                "example": 322
                                                            },
                                                            "size_value": {
                                                                "type": "number",
                                                                "example": 500
                                                            },
                                                            "size_unit": {
                                                                "type": "string",
                                                                "example": "gm"
                                                            },
                                                            "price": {
                                                                "type": "number",
                                                                "format": "float",
                                                                "example": 1778.28
                                                            },
                                                            "previous_price": {
                                                                "type": "number",
                                                                "format": "float",
                                                                "example": 2044,
                                                                "nullable": true
                                                            }
                                                        },
                                                        "type": "object"
                                                    }
                                                },
                                                "featured_image": {
                                                    "type": "string",
                                                    "example": "http://192.168.100.23:8008/storage/601/medi-plaster.png"
                                                },
                                                "gallery_images": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "string",
                                                        "example": "http://192.168.100.23:8008/storage/602/tablets.jpg"
                                                    }
                                                },
                                                "liked": {
                                                    "type": "boolean",
                                                    "example": false
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
