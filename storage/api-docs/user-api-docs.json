                                                            },
                                                            "price": {
                                                                "type": "number",
                                                                "format": "float",
                                                                "example": 2016.7
                                                            },
                                                            "previous_price": {
                                                                "type": "number",
                                                                "format": "float",
                                                                "example": 2345,
                                                                "nullable": true
                                                            },
                                                            "feature_image": {
                                                                "type": "string",
                                                                "example": "http://192.168.100.23:8008/storage/576/visc-inhaler.jpg"
