                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/product/{slug}": {
            "get": {
                "tags": [
                    "Product"
                ],
                "summary": "Show an product",
                "description": "Show an active brand.",
                "operationId": "ProductShow",
                "parameters": [
                    {
                        "name": "slug",
                        "in": "path",
